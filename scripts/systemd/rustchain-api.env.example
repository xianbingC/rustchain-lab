# RustChain API 服务环境变量示例
# 使用方法：
# 1) 复制到 /etc/rustchain/rustchain-api.env
# 2) 按需修改值
# 3) 重启服务：systemctl restart rustchain-api

# REST API 监听地址与端口
RUSTCHAIN_API_HOST=0.0.0.0
RUSTCHAIN_API_PORT=8080

# P2P 绑定地址
RUSTCHAIN_P2P_BIND_ADDR=0.0.0.0:7000

# 日志级别：trace/debug/info/warn/error
RUSTCHAIN_LOG_LEVEL=info

# 链数据目录（RocksDB 状态库 + LevelDB 历史库）
RUSTCHAIN_DATA_DIR=/var/lib/rustchain

# PoW 初始难度与挖矿奖励
RUSTCHAIN_MINING_DIFFICULTY=2
RUSTCHAIN_MINING_REWARD=50

# 动态难度参数：目标出块时间（秒）与调整窗口（区块数）
RUSTCHAIN_TARGET_BLOCK_TIME_SECS=10
RUSTCHAIN_DIFFICULTY_ADJUSTMENT_INTERVAL=10
